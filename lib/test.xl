
tokens =
    ID = [A-Za-z][A-Za-z0-9]*
    @skip WHITESPACE = [ \t\n\f]

import =
    "import" name:STRING -> Import(name)

func =
    "func" name:ID "(" (param ",")* param? ")" ("->" type)? ->
        Func(name, param[], type?, stmt[])

param =
    name:ID ":" type -> Param(name, type)

type =
    name:ID -> Type(name)

block[] =
    "{" statement* "}" -> statement[]

stmt =
    expr ";" -> expr
    condition:expr "->" stmt -> Branch(condition, [stmt])
    condition:expr "->" block -> Branch(condition, block)

expr =
    unaryExpr -> unaryExpr
    l:expr op:("*" | "/") r:expr -> BinaryExpr(op, l, r)
    l:expr op:("+" | "-") r:expr -> BinaryExpr(op, l, r)
    l:expr op:("<" | ">") r:expr -> BinaryExpr(op, l, r)
    l:expr op:("<=" | ">=") r:expr -> BinaryExpr(op, l, r)
    l:expr op:("==" | "!=") r:expr -> BinaryExpr(op, l, r)
    l:expr op:"and" r:expr -> BinaryExpr(op, l, r)
    l:expr op:"or" r:expr -> BinaryExpr(op, l, r)

unaryExpr =
    primaryExpr -> primaryExpr
    "-" arg:primaryExpr -> UnaryExpr("-", arg)

primaryExpr =
    "(" expr ")" -> expr
    name:ID -> Variable(name)
    func:primaryExpr "(" ( arg:expr "," )* arg:expr? ")" -> FuncCall(func, arg[])


