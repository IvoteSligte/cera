
func fibonacci(i: int) -> int {
    if i <= 0; { return 0; }
    if i == 1; { return 1; }
    return fibonacci(i - 1) + fibonacci(i - 2);
}

func main() {
    if fibonacci(6) == 8; {
        print_string("correct answer\n");
    } else {
        print_string("incorrect answer\n");
    }
}
===
correct answer
