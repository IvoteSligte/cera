// OUTPUT: "99 123 false"

struct Car {
    speed: int,
    mileage: int,
}

struct Vehicle {
    car: Car,
    can_fly: bool,
}

func main() {
    vehicle := Vehicle.{
        can_fly: false,
        car: Car.{
            speed: 99,
            mileage: 123,
        },
    };
    print_int(vehicle.car.speed);
    print_str(" ");
    print_int(vehicle.car.mileage);
    print_str(" ");
    print_bool(vehicle.can_fly);
}
