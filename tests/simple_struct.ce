// OUTPUT: "true\n10\nthree\n"

struct Config {
    one: bool,
    two: int,
    three: string,
}
func main() {
    config := Config.{
        one: true,
        two: 10,
        three: "three",
    };
    print_bool(config.one); print_string("\n");
    print_int(config.two); print_string("\n");
    print_string(config.three); print_string("\n");
}
